# Stackbox environment variables
# Copy to .env and fill in values before running ./scripts/dev.sh
# See .env.schema for full documentation of each variable.

# ── Tauri / App ───────────────────────────────────────────────────────────────
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# ── GitHub Integration ────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── Memory / Embeddings ───────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
LOG_DIR=
