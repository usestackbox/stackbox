{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "stackbox",
  "version": "0.1.0",
  "identifier": "com.stackbox.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "width": 1200,
        "height": 650,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "focus": true,
        "visible": true,
        "titleBarStyle": "Overlay",
        "title": ""
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default", "webview"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGQzEyQTRCMkRFMUZFMDIKUldRQy91RXRTeXJCLzBrVHBtWldWRXBMRTBlMWdVYlluMXRUaTdDaDR2b0I3YmdKTEIvYW1pSngK",
      "endpoints": [
        "https://github.com/usestackbox/stackbox/releases/latest/download/latest.json"
      ]
    }
  }
}
