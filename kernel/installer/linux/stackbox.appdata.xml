<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.stackbox.app</id>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <name>Stackbox</name>
  <summary>AI-powered developer workspace</summary>
  <description>
    <p>
      Stackbox is a local-first, AI-powered developer workspace that combines
      a terminal, file editor, git panel, and AI agent into a single native app.
    </p>
    <ul>
      <li>Integrated terminal with split panes</li>
      <li>Built-in file editor with syntax highlighting</li>
      <li>Git management: branches, commits, diffs, worktrees</li>
      <li>AI agent powered by MCP servers</li>
      <li>Persistent memory and context</li>
    </ul>
  </description>
  <launchable type="desktop-id">stackbox.desktop</launchable>
  <url type="homepage">https://github.com/stackbox/stackbox</url>
  <url type="bugtracker">https://github.com/stackbox/stackbox/issues</url>
  <provides>
    <binary>stackbox</binary>
  </provides>
  <releases>
    <release version="0.1.0" date="2024-01-01">
      <description><p>Initial release.</p></description>
    </release>
  </releases>
  <content_rating type="oars-1.1"/>
</component>
