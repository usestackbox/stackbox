root = true

[*]
indent_style              = space
indent_size               = 2
end_of_line               = lf
charset                   = utf-8
trim_trailing_whitespace  = true
insert_final_newline      = true

# Rust uses 4 spaces
[*.rs]
indent_size = 4

# Markdown trailing spaces are intentional (line breaks)
[*.md]
trim_trailing_whitespace = false

# Cargo and other TOML files
[*.toml]
indent_size = 4